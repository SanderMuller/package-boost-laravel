{
    "name": "sandermuller/package-boost-laravel",
    "description": "AI agent skills for Laravel package authors. Adds Laravel-flavored skills + .mcp.json emission on top of package-boost-php.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "sandermuller",
        "package-boost",
        "ai",
        "claude",
        "laravel",
        "testbench",
        "package-development",
        "developer-tools"
    ],
    "homepage": "https://github.com/sandermuller/package-boost-laravel",
    "authors": [
        {
            "name": "Sander Muller",
            "email": "github@scode.nl",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^12.0||^13.0",
        "illuminate/support": "^12.0||^13.0",
        "sandermuller/boost-core": "^0.7",
        "sandermuller/package-boost-php": "^0.9"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.3",
        "larastan/larastan": "^3.9",
        "laravel/boost": "^2.0||^3.0",
        "laravel/pao": "^1.0",
        "laravel/pint": "^1.29",
        "mrpunyapal/rector-pest": "^0.2",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.0||^11.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.4",
        "rector/type-perfect": "^2.1",
        "sandermuller/boost-skills": "^1.3",
        "spaze/phpstan-disallowed-calls": "^4.10",
        "symplify/phpstan-extensions": "^12.0",
        "tomasvotruba/cognitive-complexity": "^1.1",
        "tomasvotruba/type-coverage": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "SanderMuller\\PackageBoostLaravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SanderMuller\\PackageBoostLaravel\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "extra": {
        "boost": {
            "emitters": [
                "SanderMuller\\PackageBoostLaravel\\Emitters\\McpJsonEmitter"
            ]
        },
        "laravel": {
            "providers": [
                "SanderMuller\\PackageBoostLaravel\\PackageBoostLaravelServiceProvider"
            ]
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare"
        ],
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "post-install-cmd": [
            "SanderMuller\\BoostCore\\Scripts\\BoostAutoSync::run"
        ],
        "post-update-cmd": [
            "SanderMuller\\BoostCore\\Scripts\\BoostAutoSync::run"
        ],
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=2G",
        "phpstan-simplified": "vendor/bin/phpstan analyse --memory-limit=2G --error-format symplify",
        "phpstan-clear-cache": "vendor/bin/phpstan clear-result-cache",
        "format": "vendor/bin/pint",
        "rector": "vendor/bin/rector process",
        "sync-ai": "vendor/bin/boost sync",
        "qa": [
            "@rector",
            "@format",
            "@phpstan-simplified"
        ],
        "qa-check": [
            "vendor/bin/rector process --dry-run",
            "vendor/bin/pint --test",
            "@phpstan-simplified",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
